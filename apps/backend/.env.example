# Database — PostgreSQL connection (use docker:up for local dev)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=laughtrack
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/laughtrack

# better-auth — generate a random secret: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Public verify-email page URL (should point to the public web/marketing app, not the backend auth host)
PUBLIC_WEB_URL=http://localhost:3001

# Google OAuth — get from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Transactional email / SMTP
# Use EMAIL_TRANSPORT=stub for automated tests/local stub mode, or EMAIL_TRANSPORT=smtp for real delivery.
EMAIL_TRANSPORT=stub
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Laughtrack
SMTP_FROM_EMAIL=no-reply@laughtrack.app

# Server
PORT=3000
NODE_ENV=development
